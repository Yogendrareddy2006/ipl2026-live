# ── Copy this to .env.local for development ──────────────────
# In Vercel dashboard: Settings → Environment Variables

# 1. MongoDB Atlas free cluster
#    Get at: https://cloud.mongodb.com (free M0 tier)
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/ipl2026

# 2. Anthropic Claude API key
#    Get at: https://console.anthropic.com → API Keys
#    Cost: ~₹0.003 per match fetch (basically free)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxx

# 3. Cron security secret (make up any random string)
CRON_SECRET=my-secret-key-123

# Frontend (auto-set by Vercel, don't change)
VITE_API_BASE=/api
